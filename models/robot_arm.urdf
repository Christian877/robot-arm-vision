<?xml version="1.0"?>
<robot name="robot_arm_5dof">

  <!-- ============================================================
       MATERIALS
  ============================================================ -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.2 0.2 1.0"/>
  </material>

  <!-- ============================================================
       BASE LINK — socle fixe
  ============================================================ -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 1 — rotation base (θ₁) axe Z
  ============================================================ -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child  link="link_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-3.14159" upper="3.14159"
            effort="10" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ============================================================
       LINK 1 — colonne verticale
  ============================================================ -->
  <link name="link_1">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 2 — épaule (θ₂) axe Y
  ============================================================ -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child  link="link_2"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-1.5708" upper="1.5708"
            effort="10" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ============================================================
       LINK 2 — bras supérieur (200mm)
  ============================================================ -->
  <link name="link_2">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.20"/>
      </geometry>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.20"/>
      </geometry>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0004" ixy="0" ixz="0"
               iyy="0.0004" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 3 — coude (θ₃) axe Y
  ============================================================ -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child  link="link_3"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-2.09440" upper="2.09440"
            effort="8" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ============================================================
       LINK 3 — avant-bras (150mm)
  ============================================================ -->
  <link name="link_3">
    <visual>
      <geometry>
        <box size="0.035 0.035 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.035 0.035 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0" izz="0.00008"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 4 — poignet pitch (θ₄) axe Y
  ============================================================ -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child  link="link_4"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-1.5708" upper="1.5708"
            effort="5" velocity="1.5"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- ============================================================
       LINK 4 — poignet
  ============================================================ -->
  <link name="link_4">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT 5 — poignet roll (θ₅) axe Z
  ============================================================ -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child  link="link_5"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-3.14159" upper="3.14159"
            effort="3" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- ============================================================
       LINK 5 — effecteur final (pince)
  ============================================================ -->
  <link name="link_5">
    <visual>
      <geometry>
        <box size="0.06 0.02 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.02 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
  </link>

  <!-- ============================================================
       JOINT EFFECTEUR — point de référence pince
  ============================================================ -->
  <joint name="joint_ee" type="fixed">
    <parent link="link_5"/>
    <child  link="end_effector"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <link name="end_effector">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

</robot>